# Netlify / frontend proxy behavior
VITE_NETLIFY_LITE=false
FLOWISE_API_BASE_URL=

# Render / Flowise writable storage root
FLOWISE_FILE_STORAGE_PATH=/var/data/.flowise

# Render boot wrapper HOME/XDG path'lerini writable alana taşır.
# Bunları genelde ayrıca set etmek gerekmez; render-start.sh export eder.
# Ama gerektiğinde override edilebilir:
# HOME=/var/data/home
# XDG_CONFIG_HOME=/var/data/.config
# XDG_DATA_HOME=/var/data/.local/share
# XDG_CACHE_HOME=/var/data/.cache

# LangSmith tracing latency warning için önerilir
LANGCHAIN_CALLBACKS_BACKGROUND=true

# Render Postgres kullanılıyorsa repo zaten DATABASE_URL desteğini kabul ediyor.
DATABASE_URL=
